# bench.env — Environment-specific configuration for benchmark infrastructure.
# Copy to bench.env.local and customize for your environment.
# All deploy/benchmark scripts source this file.

# Azure resource group for benchmark cluster
BENCH_RESOURCE_GROUP="loom-bench"

# AKS cluster name
BENCH_CLUSTER_NAME="loom-bench-aks"

# Azure region
BENCH_LOCATION="eastus"

# Azure Container Registry name (must already exist)
BENCH_ACR_NAME="loomcloudacr"

# ACR login server (derived from ACR name)
BENCH_ACR_LOGIN_SERVER="${BENCH_ACR_NAME}.azurecr.io"

# Docker image name
BENCH_IMAGE="${BENCH_ACR_LOGIN_SERVER}/loom-bench"

# Server node pool VM size (32 vCPU, 256 GB — Intel Xeon, ESv5 family has 208 quota)
BENCH_SERVER_VM_SIZE="Standard_E32s_v5"

# Harness node pool VM size (16 vCPU, 128 GB — Intel Xeon, ESv5 family)
BENCH_HARNESS_VM_SIZE="Standard_E16s_v5"

# System node pool VM size (minimal, kube-system only)
BENCH_SYSTEM_VM_SIZE="Standard_D2s_v5"

# Availability zone (both pools must be in the same zone)
BENCH_ZONE="1"

# gRPC port for the benchmark server
BENCH_GRPC_PORT="60051"

# K8s namespace
BENCH_NAMESPACE="loom-bench"
