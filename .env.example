# Loom × Dreambase meetup — local dev/test environment.
#
# Copy to `.env` (gitignored) and fill in real values. Before running looms/loom
# or the test harness:  set -a; source .env; set +a
#
# Loom reads LOOM_* vars via viper (prefix LOOM, config-key dots -> underscores).
# The SUPABASE_*/NGROK_*/DREAMBASE_* block is consumed by the test harness only.

# ─────────────────────────────────────────────────────────────────────────────
# Loom runtime
# ─────────────────────────────────────────────────────────────────────────────

# Storage -> Supabase Postgres, SESSION MODE only (port 5432, NOT the 6543 pooler).  [Gate A]
LOOM_STORAGE_BACKEND=postgres
LOOM_STORAGE_POSTGRES_DSN=postgresql://postgres.<project_ref>:<db_password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
LOOM_STORAGE_MIGRATION_AUTO_MIGRATE=true

# LLM provider so loom_weave actually runs (any one provider).  [Gate A]
LOOM_LLM_PROVIDER=anthropic
LOOM_LLM_ANTHROPIC_API_KEY=

# Native Supabase-JWT auth of Loom endpoints (Phase 1C).  [Gate B]
# The HS256 jwt_secret both signs test tokens and is what the server validates.
LOOM_SERVER_AUTH_ENABLED=true
LOOM_SERVER_AUTH_PROVIDER=supabase
LOOM_SERVER_AUTH_MODE=required
LOOM_SERVER_AUTH_SUPABASE_PROJECT_REF=
LOOM_SERVER_AUTH_SUPABASE_JWT_SECRET=
LOOM_SERVER_AUTH_SUPABASE_AUDIENCE=authenticated

# Storage SupabaseConfig DB password (Phase 2B), when configuring by project_ref
# instead of a full DSN. Never commit this; keep it here or in the keyring only.
LOOM_SUPABASE_DB_PASSWORD=

# Admin endpoint token + autonomous-run convenience.
LOOM_ADMIN_TOKEN=
LOOM_YOLO=true

# ─────────────────────────────────────────────────────────────────────────────
# Test harness (consumed by the tester, NOT by looms)
# ─────────────────────────────────────────────────────────────────────────────

# Mint Supabase-style HS256 JWTs to exercise auth end-to-end (= jwt_secret above).
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_REGION=

# Public HTTPS tunnel so Dreambase (cloud) can reach the local HTTP-MCP port.  [Gate E]
NGROK_AUTHTOKEN=

# Dreambase browser automation login (use a throwaway/test account).  [Gate E]
DREAMBASE_EMAIL=
DREAMBASE_PASSWORD=

# OPTIONAL: only for rehearsing the real `loom login` GitHub consent in-browser.
# Prefer a dedicated test account with 2FA disabled, or click "Authorize" manually.
GITHUB_TEST_USER=
GITHUB_TEST_PASSWORD=
